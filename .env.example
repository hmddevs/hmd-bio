# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/hmdbio?retryWrites=true&w=majority

# NextAuth
AUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32
AUTH_URL=https://hmd.bio

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# YOURLS → MongoDB real-time sync
SYNC_SECRET=generate-a-secret-for-yourls-webhook

# Internal middleware → API secret
INTERNAL_SECRET=generate-a-secret-for-internal-calls

# IP hashing salt (GDPR)
IP_HASH_SALT=generate-a-random-salt

# YOURLS API (for catchup-sync script)
YOURLS_API_URL=https://your-yourls-domain/yourls-api.php
YOURLS_API_SIGNATURE=your-yourls-api-signature

# Sentry (optional)
SENTRY_DSN=

# Legacy MySQL (for migration only — remove after migration)
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
