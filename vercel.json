{
  "framework": "nextjs",
  "regions": ["lhr1"],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.hmd.bio" }],
      "destination": "https://hmd.bio/:path",
      "permanent": true
    },
    {
      "source": "/register",
      "destination": "/signup",
      "permanent": true
    },
    {
      "source": "/api/v1/auth/register",
      "destination": "/api/v1/auth/signup",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/preview/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/(favicon\\.ico|icon|apple-icon|opengraph-image)(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(sitemap\\.xml|robots\\.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
